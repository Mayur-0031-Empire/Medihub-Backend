PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name
ACCESS_TOKEN_SECRET=replace_with_a_long_random_access_secret
REFRESH_TOKEN_SECRET=replace_with_a_long_random_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:5000
VIDEO_CALL_BASE_URL=http://localhost:3000/consultation
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google OAuth login
# Create these in Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID.
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Must exactly match the authorized redirect URI in Google Cloud.
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
# Where the backend redirects the browser after OAuth succeeds.
OAUTH_FRONTEND_CALLBACK_URL=http://localhost:3000/auth/callback

GEMINI_API_KEY=your_gemini_api_key
PROJECT_NAME=projects/your_project_id
PROJECT_N=your_project_name
PROJECT_ID=your_project_id
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=900

# Google Maps Platform
# Enable Places API (New) for server-side hospital search and Place Photos.
GOOGLE_PLACES_API_KEY=your_server_restricted_google_places_api_key
# Enable Maps JavaScript API for the frontend map. Restrict this key by HTTP referrer.
GOOGLE_MAPS_BROWSER_API_KEY=your_browser_restricted_google_maps_javascript_api_key
# Optional, but recommended for AdvancedMarkerElement on Google Maps JS.
GOOGLE_MAPS_MAP_ID=your_google_maps_map_id
GOOGLE_PLACES_LANGUAGE_CODE=en
GOOGLE_PLACES_REGION_CODE=IN
GOOGLE_MAPS_DEFAULT_LATITUDE=20.5937
GOOGLE_MAPS_DEFAULT_LONGITUDE=78.9629
GOOGLE_MAPS_DEFAULT_ZOOM=12
